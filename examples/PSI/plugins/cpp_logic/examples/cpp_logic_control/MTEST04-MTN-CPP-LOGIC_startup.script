# Native control helper example using direct EL7041 item bindings.
#
# The staged cpp logic library lives in the IOC-local bin directory:
#   bin/main.so
#   cfg/libmain.so_cpp_logic.subs
#
# Useful panels after startup:
#   caqtdm -macro "IOC=MTEST04-MTN-CPP-LOGIC" ecmcCppLogicOverview.ui
#   caqtdm -macro "IOC=MTEST04-MTN-CPP-LOGIC,CPP_ID=0" ecmcCppLogic.ui
#   caqtdm MTEST04-MTN-CPP-LOGIC_cpp_logic.ui

require ecmccfg sandst_a "ECMC_VER=struc"
${SCRIPTEXEC} ${ecmccfg_DIR}addSlave.cmd, "SLAVE_ID=14,HW_DESC=EL7041-0052"
${SCRIPTEXEC} ${ecmccfg_DIR}applyComponent.cmd, "COMP=Motor-Generic-2Phase-Stepper,MACROS='I_MAX_MA=500,I_STDBY_MA=200,U_NOM_MV=48000,R_COIL_MOHM=1230'"
${SCRIPTEXEC} ${ecmccfg_DIR}loadCppLogic.cmd, "REPORT=1"
